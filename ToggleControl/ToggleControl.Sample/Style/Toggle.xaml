<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:toggleControl="clr-namespace:ToggleControl;assembly=ToggleControl">

    <Style TargetType="{x:Type toggleControl:Toggle}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource PrimaryElement}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SwitcherMargin" Value="4"/>
        <Setter Property="SwitcherColor" Value="{DynamicResource BackgroundPrimary}"/>
        <Setter Property="CheckIconColor" Value="{DynamicResource BackgroundSecondary}"/>
        <Setter Property="UncheckIconColor" Value="{DynamicResource ForegroundSecondary}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundPrimary}"/>

        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.56"/>
            </Trigger>

            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True"/>
                    <Condition Property="IsChecked" Value="True"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundHover}"/>
                    <Setter Property="Background" Value="{DynamicResource PrimaryElementHover}"/>
                </MultiTrigger.Setters>
            </MultiTrigger>

            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True"/>
                    <Condition Property="IsChecked" Value="False"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundHover}"/>
                    <Setter Property="Background" Value="{DynamicResource SecondaryElementHover}"/>
                </MultiTrigger.Setters>
            </MultiTrigger>

            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="False"/>
                    <Condition Property="IsChecked" Value="True"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter Property="Background" Value="{DynamicResource PrimaryElement}"/>
                </MultiTrigger.Setters>
            </MultiTrigger>

            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="False"/>
                    <Condition Property="IsChecked" Value="False"/>
                </MultiTrigger.Conditions>
                <MultiTrigger.Setters>
                    <Setter Property="Background" Value="{DynamicResource SecondaryElement}"/>
                </MultiTrigger.Setters>
            </MultiTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>