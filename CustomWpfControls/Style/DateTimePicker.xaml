    <Style x:Key="DateTimePicker_TextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type customWpfControls:DateTimePicker}}}"/>
        <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type customWpfControls:DateTimePicker}}}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="200"/>
        <!--<Setter Property="CaretBrush" Value="Transparent"/>-->
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource ForegroundHover}"/>
    </Style>

    <Style x:Key="DateTimePicker_SelectorPopup" TargetType="{x:Type Popup}">
        <Setter Property="MinWidth" Value="180"/>
        <Setter Property="MinHeight" Value="200"/>
        <Setter Property="Placement" Value="Left"/>
        <Setter Property="IsOpen" Value="False"/>
        <Setter Property="StaysOpen" Value="False"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
    </Style>

    <Style TargetType="{x:Type customWpfControls:DateTimePicker}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type customWpfControls:DateTimePicker}">
                    <Grid Background="{TemplateBinding Background}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 x:Name="PART_DateTimeTextBox"
                                 Style="{StaticResource DateTimePicker_TextBox}"
                                 TabIndex="0"/>

                        <Grid Grid.Column="1">
                            <Button x:Name="PART_SelectButton"
                                    Height="32"
                                    Width="32"
                                    Style="{DynamicResource FlatButton}" 
                                    Focusable="False"
                                    KeyboardNavigation.TabNavigation="None">
                                <Viewbox Stretch="None">
                                    <Canvas Width="32" Height="32" Margin="3 3 0 0">
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Button}}}"
                                              Data="{StaticResource Calendar}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Popup x:Name="PART_SelectorPopup" 
                                   Style="{StaticResource DateTimePicker_SelectorPopup}">

                                <Border Background="{DynamicResource DateTimePanelBackground}" 
                                        CornerRadius="5">
                                    <Grid HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Background="Transparent">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Calendar Grid.Row="0" 
                                                  x:Name="PART_Calendar"
                                                  Margin="0 5 0 0"
                                                  Width="185"
                                                  Height="180"
                                                  Focusable="False"
                                                  SelectionMode="SingleDate"/>

                                        <StackPanel Grid.Row="1" 
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0 -5 0 5">
                                            <TextBlock Background="Transparent"
                                                       Foreground="{DynamicResource ForegroundPrimary}"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       Margin="0 0 5 0">
                                                Время:
                                            </TextBlock>
                                            <customWpfControls:TimePicker x:Name="PART_TimePicker"/>

                                            <Path Fill="{DynamicResource ForegroundSecondary}"
                                                  Stretch="Fill"
                                                  Margin="15 2 0 0"
                                                  Width="16"
                                                  Height="16"
                                                  Data="{StaticResource Question}">
                                                <Path.ToolTip>
                                                    <ToolTip>
                                                        <StackPanel Orientation="Vertical">
                                                            <TextBlock Text="При зажатом Alt - время изменяется на 5 минут."/>
                                                            <TextBlock Text="При зажатом Ctrl - время изменяется на 10 минут."/>
                                                            <TextBlock Text="При зажатом Shift - время изменяется на 1 час."/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Path.ToolTip>
                                            </Path>
                                        </StackPanel>

                                        <Separator Grid.Row="2" 
                                                   Background="{DynamicResource BorderPrimary}"
                                                   Margin="5 0"/>

                                        <Grid Grid.Row="3" Margin="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="1" 
                                                    x:Name="PART_CancelButton"
                                                    Margin="0 0 15 0"
                                                    Style="{DynamicResource FlatButton}"
                                                    Content="Отмена"/>

                                            <Button Grid.Column="2"
                                                    x:Name="PART_SaveButton"
                                                    Width="45"
                                                    Height="32"
                                                    Style="{DynamicResource YellowRoundedButton}"
                                                    Content="Ок"/>
                                        </Grid>
                                    </Grid>

                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>