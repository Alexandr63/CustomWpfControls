<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:customWpfControls="clr-namespace:CustomWpfControls">

    <Geometry x:Key="UpArrow">F1 M31,15z M0,0z M0,15L31,15 15,0</Geometry>
    <Geometry x:Key="DownArrow">F1 M31,15z M0,0z M0,0L31,0 15,15</Geometry>

    <Style x:Key="TimePicker_TextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type customWpfControls:TimePicker}}}"/>
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type customWpfControls:TimePicker}}}"/>
        <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type customWpfControls:TimePicker}}}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="CaretBrush" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="Background" Value="{DynamicResource SecondaryElementHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <Style x:Key="TimePicker_SplitterTextBlock" TargetType="{x:Type TextBlock}">
        <Setter Property="Margin" Value="4 0"/>
        <Setter Property="Background" Value="{Binding Background, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type customWpfControls:TimePicker}}}"/>
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type customWpfControls:TimePicker}}}"/>
        <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type customWpfControls:TimePicker}}}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Text" Value=":"/>
    </Style>

    <Style TargetType="{x:Type customWpfControls:TimePicker}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Width" Value="85"/>
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type customWpfControls:TimePicker}">
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 x:Name="PART_HoursTextBox"
                                 Style="{StaticResource TimePicker_TextBox}"
                                 TabIndex="0"/>

                        <TextBlock Grid.Column="1"
                                   x:Name="PART_SlitterTextBox"
                                   Style="{StaticResource TimePicker_SplitterTextBlock}"/>

                        <TextBox Grid.Column="2"
                                 x:Name="PART_MinutesTextBox"
                                 Style="{StaticResource TimePicker_TextBox}"
                                 TabIndex="1"/>

                        <Grid Grid.Column="3" 
                              Width="32">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" 
                                    x:Name="PART_UpButton"
                                    Style="{DynamicResource FlatButton}"
                                    VerticalAlignment="Top"
                                    Width="20" 
                                    Height="17"
                                    TabIndex="2">
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="30" Height="30">
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Button}}}"
                                              Data="{StaticResource UpArrow}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Button Grid.Row="1" 
                                    x:Name="PART_DownButton"
                                    Style="{DynamicResource FlatButton}"
                                    VerticalAlignment="Top"
                                    Width="20" 
                                    Height="17"
                                    Margin="0 0 0 -10"
                                    TabIndex="3">
                                <Viewbox Stretch="Fill">
                                    <Canvas Width="30" Height="30">
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Button}}}"
                                              Data="{StaticResource DownArrow}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>