<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dateTimePickerControl="clr-namespace:DateTimePickerControl;assembly=DateTimePickerControl">

    <Style x:Key="DateTimePicker_TextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type dateTimePickerControl:DateTimePicker}}}"/>
        <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type dateTimePickerControl:DateTimePicker}}}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="200"/>
        <Setter Property="CaretBrush" Value="Transparent"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource ForegroundHover}"/>
    </Style>

    <!-- TODO После отладки использовать заготовленный стиль для кнопки -->
    <Style x:Key="DateTimePicker_SelectButton" TargetType="{x:Type Button}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundSecondary}"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Margin" Value="2 0.5 8 0"/>
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Viewbox Stretch="Fill" Margin="3 3 -5 -4">
                        <Canvas Width="32" Height="32">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Button}}}"
                                  Data="F1 M24,24z M0,0z M0,0L20,0A4,4,0,0,1,24,4L24,24 24,24 4,24 4,24A4,4,0,0,1,0,20L0,4 2,4 2,20A2,2,0,0,0,4,22L22,22 22,4 0,4 M5,9A1,1,0,0,0,8,9A1,1,0,0,0,5,9 M10,9A1,1,0,0,0,13,9A1,1,0,0,0,10,9 M15,9A1,1,0,0,0,18,9A1,1,0,0,0,15,9 M5,16A1,1,0,0,0,8,16A1,1,0,0,0,5,16 M10,16A1,1,0,0,0,13,16A1,1,0,0,0,10,16z" />
                        </Canvas>
                    </Viewbox>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource SecondaryElementHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource SecondaryElementPressed}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DateTimePicker_SelectorPopup" TargetType="{x:Type Popup}">
        <Setter Property="MinWidth" Value="180"/>
        <Setter Property="MinHeight" Value="200"/>
        <Setter Property="Placement" Value="Left"/>
        <Setter Property="IsOpen" Value="False"/>
        <Setter Property="StaysOpen" Value="False"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
    </Style>

    <Style x:Key="DateTimePicker_Calendar" TargetType="{x:Type Calendar}">
        <Setter Property="Width" Value="180"/>
        <Setter Property="Height" Value="180"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="SelectionMode" Value="SingleDate"/>
    </Style>

    <!-- TODO После отладки использовать заготовленный стиль для кнопки (FlatButton)-->
    <Style x:Key="PART_CancelButton" TargetType="{x:Type Button}">
        <Setter Property="Margin" Value="0 0 10 0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Width" Value="60"/>
        <Setter Property="Content" Value="Отмена"/>
    </Style>

    <!-- TODO После отладки использовать заготовленный стиль для кнопки (YellowButton)-->
    <Style x:Key="PART_SaveButton" TargetType="{x:Type Button}">
        <Setter Property="Margin" Value="0 0 10 0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Width" Value="60"/>
        <Setter Property="Content" Value="Ок"/>
    </Style>

    <Style TargetType="{x:Type dateTimePickerControl:DateTimePicker}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type dateTimePickerControl:DateTimePicker}">
                    <Grid Background="{TemplateBinding Background}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 x:Name="PART_DateTimeTextBox"
                                 Style="{StaticResource DateTimePicker_TextBox}"
                                 TabIndex="0"/>

                        <Grid Grid.Column="1">
                            <Button x:Name="PART_SelectButton"
                                    Style="{StaticResource DateTimePicker_SelectButton}" 
                                    TabIndex="2" />

                            <Popup x:Name="PART_SelectorPopup" 
                                   Style="{StaticResource DateTimePicker_SelectorPopup}">

                                <Border Background="{DynamicResource DateTimePanelBackground}" 
                                        CornerRadius="5">
                                    <Grid HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Background="Transparent">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Calendar Grid.Row="0" 
                                                  x:Name="PART_Calendar"/>

                                        <StackPanel Grid.Row="1" 
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="5 -5 5 5">
                                            <TextBlock Background="Transparent"
                                                       Foreground="{DynamicResource ForegroundPrimary}"
                                                       FontSize="14"
                                                       Margin="5">
                                                Время:
                                            </TextBlock>
                                            <dateTimePickerControl:TimePicker x:Name="PART_TimePicker"
                                                                              Width="70"
                                                                              Height="20"/>

                                            <Path Fill="{DynamicResource ForegroundSecondary}"
                                                  Stretch="Fill"
                                                  Margin="15 0 0 0"
                                                  Width="16"
                                                  Height="16"
                                                  Data="F0 M16,16z M0,0z M14,8C14,4.68629 11.3137,2 8,2 4.68629,2 2,4.68629 2,8 2,11.3137 4.68629,14 8,14 11.3137,14 14,11.3137 14,8z M16,8C16,12.4183 12.4183,16 8,16 3.58172,16 0,12.4183 0,8 0,3.58172 3.58172,0 8,0 12.4183,0 16,3.58172 16,8z M8.99915,8.98492C8.99864,8.97941 8.99825,8.97532 8.99929,8.97163 9.00229,8.96094 9.01723,8.95361 9.07542,8.92504 9.11276,8.90671 9.1679,8.87965 9.24911,8.83735 9.35158,8.78437 9.41371,8.75211 9.47222,8.72077 10.4683,8.18717 11,7.45921 11,6.14286 11,4.42193 9.67286,3 8,3 6.38377,3 5,4.0241 5,5.5 5,6.05228 5.44772,6.5 6,6.5 6.55228,6.5 7,6.05228 7,5.5 7,5.28145 7.38029,5 8,5 8.53628,5 9,5.49685 9,6.14286 9,6.64198 8.92458,6.74523 8.52778,6.95781 8.48255,6.98204 8.43413,7.00718 8.32524,7.06352 7.44966,7.51956 7,8.0135 7,9 7,9.55229 7.44772,10 8,10 8.55229,10 9,9.55229 9,9 9,8.99391 8.99954,8.98902 8.99915,8.98492z M9,12C9,12.5523 8.55229,13 8,13 7.44772,13 7,12.5523 7,12 7,11.4477 7.44772,11 8,11 8.55229,11 9,11.4477 9,12z">
                                                <Path.ToolTip>
                                                    <ToolTip Style="{DynamicResource DateTimePicker_ToolTip}">
                                                        <StackPanel Orientation="Vertical">
                                                            <TextBlock Text="При зажатом Alt - время изменяется на 5 минут."/>
                                                            <TextBlock Text="При зажатом Ctrl - время изменяется на 10 минут."/>
                                                            <TextBlock Text="При зажатом Shift - время изменяется на 1 час."/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Path.ToolTip>
                                            </Path>
                                        </StackPanel>

                                        <Separator Grid.Row="2" 
                                                   Background="{DynamicResource BorderPrimary}"
                                                   Margin="5 0"/>

                                        <Grid Grid.Row="3" Margin="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="1" 
                                                    x:Name="PART_CancelButton"
                                                    Style="{StaticResource PART_CancelButton}"/>

                                            <Button Grid.Column="2"
                                                    x:Name="PART_SaveButton"
                                                    Style="{DynamicResource PART_SaveButton}"/>
                                        </Grid>
                                    </Grid>

                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>