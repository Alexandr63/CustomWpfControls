<Window x:Class="DateTimePickerControl.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dateTimePickerControl="clr-namespace:DateTimePickerControl;assembly=DateTimePickerControl"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="MainWindow"
        Background="{DynamicResource BackgroundPrimary}"
        Height="300"
        Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" 
                Width="300"
                Height="36"
                Background="DimGray" 
                BorderThickness="2" 
                BorderBrush="DarkGray"
                CornerRadius="10">
            <dateTimePickerControl:TimePicker Width="70"/>
        </Border>
        <Border Grid.Row="3" 
                Width="300"
                Background="DimGray" 
                BorderThickness="2" 
                BorderBrush="DarkGray"
                CornerRadius="10">
            <dateTimePickerControl:DateTimePicker Width="270" DateTimeFormatString="dd:MM:yyyy HH:mm"/>
        </Border>
    </Grid>
</Window>
